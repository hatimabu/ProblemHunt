# Handle line endings automatically for files detected as text
# and normalize them to LF in the repository.
* text=auto eol=lf

# These are explicitly text files and should always use LF
*.ts      text eol=lf
*.tsx     text eol=lf
*.js      text eol=lf
*.jsx     text eol=lf
*.json    text eol=lf
*.css     text eol=lf
*.html    text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.xml     text eol=lf
*.svg     text eol=lf

# Leave binary files untouched
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.eot     binary
*.pdf     binary
*.zip     binary
