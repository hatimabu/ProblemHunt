# Supabase Configuration
# Get these values from https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# API Configuration
# Use Azure Function App base URL in production.
# For local Functions emulator, set this to http://localhost:7071
# IMPORTANT: The backend (python-function/local.settings.json) and frontend must use the
# SAME Supabase project (SUPABASE_URL / VITE_SUPABASE_URL) or auth tokens will be rejected.
VITE_API_BASE_URL=https://problemhunt-api.azurewebsites.net

# Solana RPC Configuration
# Prefer an Alchemy Solana RPC URL in production for wallet-powered payouts.
VITE_ALCHEMY_SOLANA_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
